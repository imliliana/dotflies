{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "file",
    "source": "~/.config/fastfetch/art/om",
    "color": {
      "1": "38;5;208"
    }

  },
  "display": {
    "separator": " "
  },
  "modules": [
    "break",
    {
      "key": "╭── ⋅ ⋅  ⋅ ⋅ ──╮",
      "type": "custom"
    },
    {
      "key": "│{#31}   user       {#keys}│",
      "type": "title",
      "format": "{user-name}"
    },
    {
      "key": "│{#32}   distro     {#keys}│",
      "type": "os",
      "format": "{name}"
    },
    {
      "type": "shell",
      "key": "│{#33}   shell      {#keys}│",
      "format": "{pretty-name}"
    },
    {
      "type": "terminal",
      "key": "│{#34}   terminal   {#keys}│",
      "format": "{exe-name}"
    },
    {
      "type": "packages",
      "key": "│{#35}   packages   {#keys}│"
    },
    {
      "type": "terminalfont",
      "key": "│{#36}   font       {#keys}│"
    },
    {
      "key": "├── ⋅ ⋅  ⋅ ⋅ ──┤",
      "type": "custom"
    },
    {
      "type": "cpu",
      "key": "│{#31}   CPU        {#keys}│",
      "format": "{name}"
    },
    {
      "type": "gpu",
      "key": "│{#32}   GPU        {#keys}│",
      "format": "{name}"
    },
    {
      "key": "│{#33} 󰍛  memory     {#keys}│",
      "type": "memory"
    },
    {
      "type": "disk",
      "folders": "/",
      "key": "│{#34} 󰉉  disk       {#keys}│"
    },
    {
      "key": "╰── ⋅ ⋅  ⋅ ⋅ ──╯",
      "type": "custom"
    },
    "break",
    {
      "key": "    ⋅ ─   ─ ⋅",
      "type": "custom"
    },
    {
      "type": "colors",
      "paddingLeft": 1,
      "symbol": "circle"
    }
  ]
}
